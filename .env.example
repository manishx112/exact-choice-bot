# Tera Apps Script web-app URL (data + optional image proxy)
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbzW2pybtw_cj0g0BkLfSYACqDkkz3NMr6eFK74dj23L5uNviUpdu39IMliB6RuM9_jf/exec

# Groq se intent nikaalna hai toh key daalo. Khaali chhoda toh JS parser use hoga.
# ⚠️ NEXT_PUBLIC_ mat lagana — ye server-only rehni chahiye
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Image strategy: "public" (Drive public link) ya "proxy" (Apps Script blob)
NEXT_PUBLIC_IMG_MODE=proxy
